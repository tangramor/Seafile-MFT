# ================================
# 内网 Seafile 配置
# ================================
INTRANET_SEAFILE_URL=http://192.168.101.111
INTRANET_SEAFILE_TOKEN=your_intranet_api_token
INTRANET_REPO_ID=eb8d70e1-736c-4548-b1bc-01d129071a11

# ================================
# 外网 Seafile 配置
# ================================
EXTRANET_SEAFILE_URL=https://seafile.example.com
EXTRANET_SEAFILE_TOKEN=your_extranet_api_token
EXTRANET_REPO_ID=your_extranet_repo_id

# ================================
# 邮件服务配置 - 内网 SMTP
# （审核人在内网时收到的邮件，审批链接为内网地址）
# ================================
INTRANET_SMTP_HOST=smtp.example.com
INTRANET_SMTP_PORT=465
INTRANET_SMTP_USER=notify@example.com
INTRANET_SMTP_PASSWORD=your_smtp_password
INTRANET_SMTP_USE_SSL=true

# ================================
# 邮件服务配置 - 外网 SMTP
# （审核人在外网时收到的邮件，审批链接为外网地址）
# 若外网与内网共用同一 SMTP，只需填写内网配置，此处留空即可
# ================================
EXTRANET_SMTP_HOST=smtp.example.com
EXTRANET_SMTP_PORT=465
EXTRANET_SMTP_USER=notify@example.com
EXTRANET_SMTP_PASSWORD=your_smtp_password
EXTRANET_SMTP_USE_SSL=true

# 审批人邮箱（多个用逗号分隔；内网和外网邮件都发给这些人）
REVIEWER_EMAILS=reviewer1@example.com,reviewer2@example.com

# ================================
# 应用配置
# ================================
# 内网访问地址（内网邮件的审批链接）
INTRANET_APP_URL=http://192.168.101.111:8081
# 外网访问地址（外网邮件的审批链接）
EXTRANET_APP_URL=http://pan.longtubas.com:8081
# 旧版兼容字段（若未设置 INTRANET_APP_URL 则回退到此）
APP_BASE_URL=http://192.168.101.111:8081
SECRET_KEY=change-me-to-a-random-secret-key-32chars
DATABASE_URL=sqlite:///./seafile_mft.db

# Token 有效期（小时）
REVIEW_TOKEN_EXPIRE_HOURS=72

# ================================
# 轮询配置（适配 Seafile 6.x，替代 Webhook）
# ================================
# 轮询间隔（秒）：建议内网 30~60 秒，对延迟不敏感可设 300 秒
POLL_INTERVAL_SECONDS=60

# 启动时立即执行一次轮询（true/false）
POLL_ON_STARTUP=true

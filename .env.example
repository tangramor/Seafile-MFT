# ================================
# 内网 Seafile 配置
# ================================
INTRANET_SEAFILE_URL=http://seafile.internal:8000
INTRANET_SEAFILE_TOKEN=your_intranet_api_token
INTRANET_REPO_ID=your_intranet_repo_id

# ================================
# 外网 Seafile 配置
# ================================
EXTRANET_SEAFILE_URL=https://seafile.example.com
EXTRANET_SEAFILE_TOKEN=your_extranet_api_token
EXTRANET_REPO_ID=your_extranet_repo_id

# ================================
# 邮件服务配置
# ================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=notify@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=true

# 审批人邮箱（多个用逗号分隔）
REVIEWER_EMAILS=reviewer1@example.com,reviewer2@example.com

# ================================
# 应用配置
# ================================
APP_BASE_URL=http://your-server-ip:8080
SECRET_KEY=change-me-to-a-random-secret-key-32chars
DATABASE_URL=sqlite+aiosqlite:///./seafile_mft.db

# Webhook 验证密钥（在 Seafile 后台设置的 Secret）
WEBHOOK_SECRET=your_seafile_webhook_secret

# Token 有效期（小时）
REVIEW_TOKEN_EXPIRE_HOURS=72
